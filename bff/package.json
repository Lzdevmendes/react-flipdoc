{
  "name": "docswitcher-bff",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "dev:worker": "tsx watch src/workers/convertWorker.ts",
    "dev:worker:simple": "tsx watch src/workers/simpleWorker.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/convertWorker.js",
    "start:worker:simple": "node dist/workers/simpleWorker.js",
    "build": "tsc"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "express": "^4.21.2",
    "html-pdf-node": "^1.0.8",
    "ioredis": "^5.8.2",
    "mammoth": "^1.11.0",
    "marked": "^17.0.0",
    "multer": "^1.4.5-lts.1",
    "officegen": "^0.6.5",
    "p-limit": "^7.2.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.0",
    "sharp": "^0.34.5",
    "turndown": "^7.2.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.5",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.15.6",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
